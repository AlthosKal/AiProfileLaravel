{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "josiasmontag/laravel-recaptchav3": "^1.0",
        "laravel/framework": "^13.0",
        "laravel/octane": "^2.17",
        "laravel/passport": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.26",
        "laravel/tinker": "^3.0",
        "maatwebsite/excel": "^3.1",
        "mateusjunges/laravel-kafka": "^2.11",
        "nesbot/carbon": "^3.11",
        "nwidart/laravel-modules": "^13.0",
        "ramsey/uuid": "^4.9",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-data": "^4.20"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.4",
        "laravel/breeze": "^2.4",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install"
        ],
        "clear": [
            "@php artisan optimize:clear --ansi",
            "@php artisan queue:clear --ansi",
            "composer dump-autoload"
        ],
        "fresh": [
            "@clear",
            "@dev"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" --names=server,queue,logs --kill-others"
        ],
        "prod": [
            "@build:prod",
            "@start:prod"
        ],
        "start:prod": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"php artisan octane:frankenphp --host=0.0.0.0 --port=8000 --workers=auto --caddyfile=./Caddyfile\" \"php artisan pail --timeout=0\" --names=server,logs --kill-others"
        ],
        "build:prod": [
            "composer dump-autoload --optimize --classmap-authoritative --ansi",
            "@php artisan config:cache --ansi",
            "@php artisan route:cache --ansi",
            "@php artisan event:cache --ansi"
        ],
        "stan": [
            "./vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=-1"
        ],
        "pint": [
            "./vendor/bin/pint"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "Modules/*/composer.json"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
